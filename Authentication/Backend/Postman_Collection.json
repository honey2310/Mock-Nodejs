{
  "info": {
    "name": "Admin & Manager API",
    "description": "Complete API collection for Admin registration, login, and Manager management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "1. Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin1\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin@123\",\n  \"confirm_password\": \"Admin@123\",\n  \"status\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/admin/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "admin", "register"]
            }
          }
        },
        {
          "name": "2. Login Admin (Get Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/admin/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "admin", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Manager",
      "item": [
        {
          "name": "3. Create Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@company.com\",\n  \"salary\": \"50000\",\n  \"designation\": \"Senior Manager\",\n  \"phone\": \"03001234567\",\n  \"status\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/manager",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager"]
            }
          }
        },
        {
          "name": "4. Get All Managers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/manager",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager"]
            }
          }
        },
        {
          "name": "5. Delete Manager by ID",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/manager/MANAGER_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "MANAGER_ID_HERE"]
            }
          }
        },
        {
          "name": "6. Update Manager (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@company.com\",\n  \"salary\": \"60000\",\n  \"designation\": \"Director\",\n  \"phone\": \"03009876543\",\n  \"status\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/manager/MANAGER_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "MANAGER_ID_HERE"]
            }
          }
        },
        {
          "name": "7. Search Managers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/manager/search?search=John",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "search"],
              "query": [
                {
                  "key": "search",
                  "value": "John"
                }
              ]
            }
          }
        },
        {
          "name": "8. Get Managers with Pagination",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/manager/pagination?page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "pagination"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "9. Delete Multiple Managers",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\n    \"MANAGER_ID_1\",\n    \"MANAGER_ID_2\",\n    \"MANAGER_ID_3\"\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/manager/delete-multiple",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "manager", "delete-multiple"]
            }
          }
        }
      ]
    }
  ]
}
